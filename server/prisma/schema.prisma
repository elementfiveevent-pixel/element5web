datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. AUTH & ROLES
// ==========================================

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  EVENT_MANAGER
  MODERATOR
  ARTIST
  AUDIENCE
  SPONSOR
  VOLUNTEER
  JUDGE
  GUEST
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  passwordHash     String?      // Nullable for OAuth accounts
  fullName         String
  mobileNumber     String?
  profilePhotoUrl  String?
  status           UserStatus   @default(ACTIVE)
  reputationXp     Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relationships
  roles            RoleAssignment[]
  sessions         Session[]
  refreshTokens    RefreshToken[]
  artistProfile    ArtistProfile?
  registrations    EventRegistration[]
  tickets          EventTicket[]
  submissions      StageVerseSubmission[]
  scoresGiven      JudgeScore[]
  votes            Vote[]
  followers        Follow[]             @relation("Following")
  following        Follow[]             @relation("Follower")
  sentMessages     Message[]            @relation("Sender")
  receivedMessages Message[]            @relation("Recipient")
  notifications    Notification[]
  auditLogs        AuditLog[]
  bookmarks        Bookmark[]
  likes            Like[]
  comments         Comment[]
  reviews          Review[]
  activityFeed     ActivityFeed[]
  moderatedReports ModerationReport[]   @relation("Moderator")
  filedReports     ModerationReport[]   @relation("Reporter")
  communities      CommunityMember[]
  collaborationsAsRequester CollaborationRequest[] @relation("Requester")
  collaborationsAsReceiver  CollaborationRequest[] @relation("Receiver")
  organizedEvents  Event[]              @relation("Organizer")
  assignedVolunteerTasks VolunteerAssignment[]

  @@index([email])
}

model RoleAssignment {
  id        String   @id @default(uuid())
  userId    String
  role      UserRole
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

model Permission {
  id          String   @id @default(uuid())
  action      String   @unique // e.g. "event:create", "vote:cast"
  description String?
}

// ==========================================
// 2. SESSION & DEVICE MANAGEMENT
// ==========================================

model Session {
  id               String   @id @default(uuid())
  userId           String
  deviceFingerprint String?
  userAgent        String?
  ipAddress        String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  expiresAt        DateTime

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  isUsed    Boolean  @default(false)
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 3. ARTIST / CREATOR PROFILES
// ==========================================

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  BOOKED
  ON_TOUR
}

model ArtistProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  stageName          String             @unique
  biography          String?
  portfolioUrls      String[]           @default([])
  genres             String[]           @default([])
  skills             String[]           @default([])
  languages          String[]           @default([])
  isVerified         Boolean            @default(false)
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  latitude           Float?
  longitude          Float?
  city               String?
  state              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relationships
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  performances       PerformanceHistory[]
  achievements       ArtistAchievement[]

  @@index([isVerified])
}

model Achievement {
  id          String   @id @default(uuid())
  title       String   @unique
  description String
  badgeIconUrl String
  xpReward    Int

  artists     ArtistAchievement[]
}

model ArtistAchievement {
  id            String      @id @default(uuid())
  artistProfileId String
  achievementId String
  unlockedAt    DateTime    @default(now())

  artistProfile ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  achievement   Achievement   @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([artistProfileId, achievementId])
}

model PerformanceHistory {
  id              String        @id @default(uuid())
  artistProfileId String
  eventId         String
  roleDescription String?
  performanceDate DateTime
  videoUrl        String?

  artistProfile   ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ==========================================
// 4. EVENT PLATFORM
// ==========================================

enum EventCategory {
  STAGEVERSE
  FESTIVAL
  WORKSHOP
  MEETUP
  NETWORKING
  AWARDS
  PRIVATE
  EXHIBITION
  COMMUNITY
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
  ARCHIVED
}

model Event {
  id                   String              @id @default(uuid())
  organizerId          String
  title                String
  description          String?
  flyerUrl             String?
  category             EventCategory
  status               EventStatus         @default(DRAFT)
  maxCapacity          Int?
  registrationsCount   Int                 @default(0)
  startDate            DateTime
  endDate              DateTime?
  registrationEndDate  DateTime?
  isPaid               Boolean             @default(false)
  price                Decimal             @default(0.00) @db.Decimal(10, 2)
  upiQrUrl             String?
  upiVpa               String?
  termsConditions      String?
  customFields         Json                @default("[]")
  viewsCount           Int                 @default(0)
  slug                 String              @unique
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Relationships
  organizer            User                @relation("Organizer", fields: [organizerId], references: [id], onDelete: Cascade)
  location             Location?
  ticketCategories     TicketCategory[]
  registrations        EventRegistration[]
  tickets              EventTicket[]
  submissions          StageVerseSubmission[]
  performances         PerformanceHistory[]
  checkInAuditLogs     CheckInAuditLog[]
  sponsors             EventSponsor[]
  partners             EventPartner[]
  volunteerRoles       VolunteerRole[]
  announcements        EventAnnouncement[]
  media                EventMedia[]
  categories           CategoryAssignment[]
  tags                 TagAssignment[]

  @@index([status, category])
  @@index([startDate])
}

model Location {
  id           String   @id @default(uuid())
  eventId      String   @unique
  venueName    String
  venueAddress String
  mapsLink     String?
  latitude     Float?
  longitude    Float?
  city         String
  state         String

  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model TicketCategory {
  id          String   @id @default(uuid())
  eventId     String
  name        String   // VIP, General, Early Bird
  price       Decimal  @db.Decimal(10, 2)
  maxCapacity Int
  soldCount   Int      @default(0)
  description String?
  createdAt   DateTime @default(now())

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, name])
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model EventRegistration {
  id                   String        @id @default(uuid())
  eventId              String
  userId               String
  customData           Json          @default("{}")
  paymentScreenshotUrl String?
  paymentStatus        PaymentStatus @default(PENDING)
  reviewedAt           DateTime?
  teamId               String?
  isGroupBooking       Boolean       @default(false)
  groupSize            Int           @default(1)
  baseAmount           Decimal       @db.Decimal(10, 2)
  addonsAmount         Decimal       @default(0.00) @db.Decimal(10, 2)
  totalAmount          Decimal       @db.Decimal(10, 2)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relationships
  event                Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets              EventTicket[]

  @@unique([eventId, userId])
}

model EventTicket {
  id             String            @id @default(uuid())
  registrationId String
  eventId        String
  userId         String
  qrCode         String            @unique
  isUsed         Boolean           @default(false)
  usedAt         DateTime?
  createdAt      DateTime          @default(now())

  // Relationships
  registration   EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  event          Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkInLogs    CheckInAuditLog[]
}

model CheckInAuditLog {
  id                String      @id @default(uuid())
  ticketId          String
  eventId           String
  action            String      // e.g. "CHECK_IN", "REJECT_DUPLICATE"
  ipAddress         String?
  userAgent         String?
  deviceFingerprint String?
  verificationMethod String     // e.g. "QR_SCAN", "MANUAL_BYPASS"
  metadata          Json?
  createdAt         DateTime    @default(now())

  ticket            EventTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  event             Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ==========================================
// 5. STAGEVERSE & VOTING ENGINE
// ==========================================

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model StageVerseSubmission {
  id               String           @id @default(uuid())
  eventId          String
  userId           String
  trackTitle       String
  audioVideoUrl    String
  performanceOrder Int?
  status           SubmissionStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relationships
  event            Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scores           JudgeScore[]
  votes            Vote[]

  @@unique([eventId, userId])
}

model JudgeScore {
  id             String               @id @default(uuid())
  submissionId   String
  judgeId        String
  originalityScore Int
  technicalityScore Int
  engagementScore Int
  feedback       String?
  createdAt      DateTime             @default(now())

  submission     StageVerseSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  judge          User                 @relation(fields: [judgeId], references: [id], onDelete: Cascade)

  @@unique([submissionId, judgeId])
}

model Vote {
  id             String               @id @default(uuid())
  submissionId   String
  voterId        String
  weight         Int                  @default(1)
  createdAt      DateTime             @default(now())

  submission     StageVerseSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  voter          User                 @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([submissionId, voterId])
}

model LeaderboardStanding {
  id               String   @id @default(uuid())
  timeframe        String   // "WEEKLY", "MONTHLY", "SEASON", "ALL_TIME"
  timeframeKey     String   // e.g. "2026-W28", "2026-M07"
  artistProfileId  String
  rank             Int
  performanceScore Float
  audienceVotesCount Int
  judgeAverageScore Float
  totalScore       Float
  updatedAt        DateTime @default(now()) @updatedAt

  @@unique([timeframe, timeframeKey, artistProfileId])
  @@index([totalScore])
}

// ==========================================
// 6. SOCIAL & COLLABORATION
// ==========================================

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}

enum CollaborationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model CollaborationRequest {
  id           String              @id @default(uuid())
  requesterId  String
  receiverId   String
  projectTitle String
  description  String
  status       CollaborationStatus @default(PENDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  requester    User                @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver     User                @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)
}

// ==========================================
// 7. COMMUNITY & ENGAGEMENT
// ==========================================

model Community {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  bannerUrl   String?
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     CommunityMember[]
  posts       Post[]
}

model CommunityMember {
  id          String   @id @default(uuid())
  communityId String
  userId      String
  role        String   @default("MEMBER") // OWNER, MODERATOR, MEMBER
  joinedAt    DateTime @default(now())

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
}

model Post {
  id          String    @id @default(uuid())
  communityId String
  authorId    String
  title       String
  content     String
  mediaUrls   String[]  @default([])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  bookmarks   Bookmark[]
  likes       Like[]
  comments    Comment[]
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Review {
  id          String   @id @default(uuid())
  targetId    String   // Can point to an Artist or Event
  authorId    String
  rating      Int
  content     String
  createdAt   DateTime @default(now())

  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ==========================================
// 8. MESSAGES & NOTIFICATIONS
// ==========================================

model Message {
  id          String   @id @default(uuid())
  senderId    String
  recipientId String
  content     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender      User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   // "SYSTEM", "VOTE", "COLLAB", "TICKET"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 9. ORGANIZERS, SPONSORS & PARTNERS
// ==========================================

model Sponsor {
  id        String         @id @default(uuid())
  name      String         @unique
  logoUrl   String
  website   String?
  events    EventSponsor[]
}

model EventSponsor {
  id        String   @id @default(uuid())
  eventId   String
  sponsorId String
  tier      String   // Title, Gold, Silver

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsor   Sponsor  @relation(fields: [sponsorId], references: [id], onDelete: Cascade)

  @@unique([eventId, sponsorId])
}

model Partner {
  id        String         @id @default(uuid())
  name      String         @unique
  logoUrl   String
  website   String?
  events    EventPartner[]
}

model EventPartner {
  id        String   @id @default(uuid())
  eventId   String
  partnerId String
  type      String   // Media, Ticketing, Venue

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([eventId, partnerId])
}

// ==========================================
// 10. VOLUNTEERS
// ==========================================

model VolunteerRole {
  id          String   @id @default(uuid())
  eventId     String
  title       String
  description String?
  capacity    Int

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignments VolunteerAssignment[]

  @@unique([eventId, title])
}

model VolunteerAssignment {
  id              String        @id @default(uuid())
  volunteerRoleId String
  userId          String
  status          String        @default("PENDING") // PENDING, APPROVED, DECLINED
  assignedAt      DateTime      @default(now())

  volunteerRole   VolunteerRole @relation(fields: [volunteerRoleId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([volunteerRoleId, userId])
}

// ==========================================
// 11. ANNOUNCEMENTS, MEDIA, CATEGORIES & TAGS
// ==========================================

model EventAnnouncement {
  id        String   @id @default(uuid())
  eventId   String
  title     String
  content   String
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventMedia {
  id        String   @id @default(uuid())
  eventId   String
  mediaUrl  String
  type      String   // IMAGE, VIDEO
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Category {
  id        String               @id @default(uuid())
  name      String               @unique
  events    CategoryAssignment[]
}

model CategoryAssignment {
  id          String   @id @default(uuid())
  eventId     String
  categoryId  String

  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([eventId, categoryId])
}

model Tag {
  id        String          @id @default(uuid())
  name      String          @unique
  events    TagAssignment[]
}

model TagAssignment {
  id        String   @id @default(uuid())
  eventId   String
  tagId     String

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([eventId, tagId])
}

// ==========================================
// 12. AUDIT LOGS, MODERATION & REPORTS
// ==========================================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // e.g. "USER_SUSPEND", "VOTE_REMOVED", "EVENT_EDITED"
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

model ModerationReport {
  id          String       @id @default(uuid())
  reporterId  String
  targetType  String       // e.g. "POST", "COMMENT", "ARTIST"
  targetId    String
  reason      String
  status      ReportStatus @default(OPEN)
  moderatorId String?
  actionTaken String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reporter    User         @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  moderator   User?        @relation("Moderator", fields: [moderatorId], references: [id], onDelete: Cascade)
}

model ActivityFeed {
  id        String   @id @default(uuid())
  userId    String
  activity  String   // e.g. "VOTED", "REGISTERED", "POSTED"
  targetId  String?  // References post, event, etc.
  metadata  Json?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
